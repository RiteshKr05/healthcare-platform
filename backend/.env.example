# ──────────────────────────────────
# APPLICATION
# ──────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
APP_NAME=MedClaim Platform
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ──────────────────────────────────
# DATABASE — PostgreSQL
# ──────────────────────────────────
DATABASE_URL=postgresql://medclaim:medclaim_dev@localhost:5432/medclaim?schema=public

# ──────────────────────────────────
# DATABASE — MongoDB
# ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/medclaim

# ──────────────────────────────────
# CACHE — Redis
# ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ──────────────────────────────────
# OBJECT STORAGE — MinIO
# ──────────────────────────────────
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=medclaim-documents
STORAGE_USE_SSL=false

# ──────────────────────────────────
# AUTHENTICATION
# ──────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12
OTP_EXPIRY_MINUTES=5
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# ──────────────────────────────────
# EMAIL
# ──────────────────────────────────
EMAIL_PROVIDER=ethereal
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@medclaim.dev
EMAIL_FROM_NAME=MedClaim Platform

# ──────────────────────────────────
# SMS (Mock)
# ──────────────────────────────────
SMS_PROVIDER=mock

# ──────────────────────────────────
# LOGGING
# ──────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ──────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# ──────────────────────────────────
# FILE UPLOAD
# ──────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx,.xlsx,.csv

# ──────────────────────────────────
# CORS
# ──────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ──────────────────────────────────
# PAGINATION
# ──────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
